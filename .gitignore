# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# MCP config (contém tokens de API)
.mcp.json

# Claude Code — state local do dev (não commitar)
.claude/

# Credenciais OAuth baixadas do Google Cloud (NUNCA commitar)
client_secret_*.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# template de referência visual (não entra no build/git)
/modelo/
